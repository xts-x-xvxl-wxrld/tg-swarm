# tg-swarm active Telegram runtime environment
# Copy this file to `.env` and fill in the required values.

# Required: active LLM provider for the live orchestrator/specialists.
# The current runtime calls Anthropic directly.
ANTHROPIC_API_KEY=

# Required: model used by the orchestrator and specialist agents.
# Keep the provider prefix because README and repo docs expect it.
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# Optional: cheaper Anthropic model for bounded summary-style work.
# Observation review uses this by default if it is set.
SUMMARY_MODEL=anthropic/claude-haiku-3-5

# Required: Telegram Bot API token for inbound/outbound bot traffic.
TELEGRAM_BOT_TOKEN=

# Optional: set to `telethon` to enable live MTProto capabilities.
# Omit or leave unset to keep the default stub backend.
# TELEGRAM_CAPABILITY_BACKEND=telethon
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional but recommended: persistent local state/data roots.
TELEGRAM_RUNTIME_STATE_DIR=activity-logs/telegram-runtime
TG_SWARM_DATA_DIR=data

# Optional: FastAPI host/port overrides for `python server.py`.
HOST=0.0.0.0
PORT=8080

# Optional: legacy or non-runtime integrations kept elsewhere in the repo.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
SEARCH_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
FAL_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
